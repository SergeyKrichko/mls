export RED='\e[31m'
export GREEN='\e[32m'
export YELLOW='\e[33m'
export BLUE='\e[34m'
export CYAN='\e[36m'
export AQUA='\e[1;36m'
export NC='\e[0m'
color_text() {
    local color=$1
    shift
    echo -e "${color}$*${NC}"
}

install_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        color_text "$YELLOW" "[+] Install: $pkg"
        if [[ ! -f "$SESSION_DIR/apt_updated" ]]; then
            apt-get update -qq
            echo "$(date +%T) install_pkg $cmd" > "$SESSION_DIR/apt_updated"
        fi
        apt-get install -y "$pkg" || { 
            color_text "$RED" "Error: Failed to install $pkg";
            exit 1;
        }
    fi
}

setup_session() {
    local RAW_NAME="${1:-raw-session-name}"
    local SCRIPT_NAME="${0##*/}"
    
    if [[ "$SCRIPT_NAME" == "bash" || -z "$SCRIPT_NAME" ]]; then
        export SESSION_NAME=$RAW_NAME
    else
        export SESSION_NAME="${SCRIPT_NAME%.*}"
    fi
    export SESSION_DIR=$(mktemp -d -t "${SESSION_NAME}-XXXXXXXXXX")
    if [[ ! -d "$SESSION_DIR" ]]; then
        color_text "$RED" "–Ъ—А–Є—В–Є—З–µ—Б–Ї–∞—П –Њ—И–Є–±–Ї–∞: –Э–µ —Г–і–∞–ї–Њ—Б—М —Б–Њ–Ј–і–∞—В—М SESSION_DIR" >&2
        return 1
    fi
}

cleanup() {
    rm -rf "$SESSION_DIR"
    tput cnorm   # –Я–Њ–Ї–∞–Ј–∞—В—М –Ї—Г—А—Б–Њ—А
    tput rmcup   # –Т–µ—А–љ—Г—В—М –Њ—Б–љ–Њ–≤–љ–Њ–є –±—Г—Д–µ—А —В–µ—А–Љ–Є–љ–∞–ї–∞
    echo "[*] –Т–Њ–Ј–≤—А–∞—В –≤ –Њ—Б–љ–Њ–≤–љ—Г—О –Ї–Њ–љ—Б–Њ–ї—М. –Ш—Б—В–Њ—А–Є—П —Б–Њ—Е—А–∞–љ–µ–љ–∞."
}

upgrade_system(){
    echo -ne "${COLOR_SCRIPT}UPGRADE SYSTEM? [Y/n]: ${NC}"
    while true; do
        read -n 1 -r -s answer < /dev/tty
        case "$answer" in
            [Yy]|"") 
                color_text "$CYAN" "[+] UPDATE and UPGRADE (dist-upgrade)..."
                export DEBIAN_FRONTEND=noninteractive
                apt-get update && apt-get dist-upgrade -y
                echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
                if [[ -f /run/reboot-required ]]; then
                    color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                    if [[ -f /run/reboot-required.pkgs ]]; then
                        echo "[*] Packages requiring reboot:"
                        sed 's/^/    - /' /run/reboot-required.pkgs
                    fi
                fi
                break 
                ;;
            [Nn])
                color_text "$CYAN" "[-] MISSED UPGRADE."
                break 
                ;;
            *)
                ;;
        esac
    done
}

show_menu() {
    while true; do
        clear
        color_text "$COLOR_SCRIPT" "=========================================="
        color_text "$COLOR_SCRIPT" "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
        color_text "$COLOR_SCRIPT" "=========================================="

        for i in "${!MENU_ITEMS[@]}"; do
            raw_label_item="${MENU_ITEMS[$i]}"
            label_item="${raw_label_item%%|*}"
            label_item="${label_item#"${label_item%%[![:space:]]*}"}"
            label_item="${label_item%"${label_item##*[![:space:]]}"}"
            color_text "$COLOR_SCRIPT" "$((i+1))) $label_item"
        done

        color_text "$COLOR_SCRIPT" "0) Exit"
        color_text "$COLOR_SCRIPT" "=========================================="
        echo -ne "${COLOR_SCRIPT}Choice MENU: ${NC}"
        read -n 1 -r choice < /dev/tty
        echo -e "\n"

        case "$choice" in
            0) 
                color_text "$YELLOW" "–Ч–∞–≤–µ—А—И–µ–љ–Є–µ —А–∞–±–Њ—В—Л..."
                return 0 
                ;;
            [1-9])
                idx=$((choice-1))
                if (( idx >= 0 && idx < ${#MENU_ITEMS[@]} )); then
                    choice_menu_idx "$idx"
                else
                    color_text "$RED" "–Я—Г–љ–Ї—В $choice –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В"
                    echo -e "\n"
                    sleep 1
                fi
                ;;
            *)
                color_text "$RED" "–Э–µ–≤–µ—А–љ—Л–є –≤–≤–Њ–і. –Ш—Б–њ–Њ–ї—М–Ј—Г–є—В–µ 1-9 –Є–ї–Є 0"
                sleep 1
                ;;
        esac
    done
}

choice_menu_idx() {
    local idx=$1
    local raw="${MENU_ITEMS[$idx]}"
    local label="${raw%%|*}"; label="${label#"${label%%[![:space:]]*}"}"; label="${label%"${label##*[![:space:]]}"}"
    local file="${raw##*|}"; file="${file#"${file%%[![:space:]]*}"}"; file="${file%"${file##*[![:space:]]}"}"

    color_text "$CYAN" "------------------------------------------"
    color_text "$CYAN" ">>> –Ч–∞–њ—Г—Б–Ї: $label"

    if ! bash <(curl -sLf "$BASE_URL/$file"); then
        color_text "$RED" "[!] –Ь–Њ–і—Г–ї—М –Ј–∞–≤–µ—А—И–Є–ї—Б—П —Б –Њ—И–Є–±–Ї–Њ–є"
    fi
    
    color_text "$CYAN" "------------------------------------------"
    color_text "$CYAN" "–Э–∞–ґ–Љ–Є—В–µ –ї—О–±—Г—О –Ї–ї–∞–≤–Є—И—Г –і–ї—П –≤–Њ–Ј–≤—А–∞—В–∞ –≤ –Љ–µ–љ—О..."
    read -rn1 _ < /dev/tty
}

export -f install_pkg
export -f color_text
export -f setup_session
export -f cleanup