check_update() {
    local mark="${1:-"check_update"}"
    local flag="$SESSION_DIR/apt_updated"

    if [[ ! -f "$flag" ]]; then
        color_text "$COLOR_SCRIPT" "==>> Обновление кэша APT ($mark)..."
        if apt-get update -y -qq; then
            echo "$(date +%T) $mark" > "$flag"
            return 0
        else
            color_text "$RED" "[!] Ошибка обновления APT. Проверьте сеть."
            return 1
        fi
    fi
    return 0
}

choice_menu_idx() {
    local idx=$1
    local raw="${MENU_ITEMS[$idx]}"
    local label="${raw%%|*}"; label="${label#"${label%%[![:space:]]*}"}"; label="${label%"${label##*[![:space:]]}"}"
    local file="${raw##*|}"; file="${file#"${file%%[![:space:]]*}"}"; file="${file%"${file##*[![:space:]]}"}"

    color_text "$COLOR_SCRIPT" "------------------------------------------"
    color_text "$COLOR_SCRIPT" ">>> Запуск: $label"

    if ! bash <(curl -sLf "$BASE_URL/$file"); then
        color_text "$RED" "[!] Модуль завершился с ошибкой"
    fi
    
    color_text "$COLOR_SCRIPT" "------------------------------------------"
    color_text "$COLOR_SCRIPT" "Нажмите любую клавишу для возврата в меню..."
    read -rn1 _ < /dev/tty
}

cleanup() {
    rm -rf "$SESSION_DIR"
    tput cnorm   # Показать курсор
    tput rmcup   # Вернуть основной буфер терминала
    echo "[*] Возврат в основную консоль. История сохранена."
}

export RED='\e[31m'
export GREEN='\e[32m'
export YELLOW='\e[33m'
export BLUE='\e[34m'
export CYAN='\e[36m'
export AQUA='\e[1;36m'
export NC='\e[0m'
color_text() {
    local flags="-e "
    while [[ "$1" == -* ]]; do
        flags+="$1 "
        shift
    done
    local color="${1:-$NC}"
    shift
    echo $flags "${color}$*${NC}"
}

input_step() {
    local prompt="$1"
    local var_name="$2"
    local mode="${3:-"ANY"}"
    local input

    while true; do
        color_text -n "$COLOR_SCRIPT" "$prompt (or '0' to abort): "

        if [[ "$mode" == "PASS" ]]; then
            read -rs input < /dev/tty
            echo ""
        else
            read -r input < /dev/tty
        fi

        if [[ "${input,,}" == "0" ]]; then
            color_text "$YELLOW" "[!] Aborted by user."
            return 1
        fi

        local valid=false
        case "$mode" in
            "IP")
                validate_ip "$input" && valid=true
                ;;
            "PASS")
                # Пароль не должен быть пустым
                [[ -n "$input" ]] && valid=true
                ;;
            "ANY"|*)
                # Любой непустой ввод
                [[ -n "$input" ]] && valid=true
                ;;
        esac

        if [[ "$valid" == "true" ]]; then
            $var_name="$input"
            return 0
        fi

        color_text "$RED" "[!] Invalid $mode format. Try again."
    done
}

install_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        color_text "$YELLOW" "[+] Install: $pkg"
        check_update "install_pkg $cmd"
        apt-get install -y "$pkg" || { 
            color_text  "$RED" "Error: Failed to install $pkg";
            return 1;
        }
    fi
}

setup_session() {
    local RAW_NAME="${1:-raw-session-name}"
    local SCRIPT_NAME="${0##*/}"
    
    if [[ "$SCRIPT_NAME" == "bash" || -z "$SCRIPT_NAME" ]]; then
        export SESSION_NAME=$RAW_NAME
    else
        export SESSION_NAME="${SCRIPT_NAME%.*}"
    fi
    export SESSION_DIR=$(mktemp -d -t "${SESSION_NAME}-XXXXXXXXXX")
    if [[ ! -d "$SESSION_DIR" ]]; then
        color_text  "$RED" "Критическая ошибка: Не удалось создать SESSION_DIR" >&2
        return 1
    fi
}

show_menu() {
    while true; do
        clear
        color_text  "$COLOR_SCRIPT" "=========================================="
        color_text  "$COLOR_SCRIPT" "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
        color_text  "$COLOR_SCRIPT" "=========================================="

        for i in "${!MENU_ITEMS[@]}"; do
            raw_label_item="${MENU_ITEMS[$i]}"
            label_item="${raw_label_item%%|*}"
            label_item="${label_item#"${label_item%%[![:space:]]*}"}"
            label_item="${label_item%"${label_item##*[![:space:]]}"}"
            color_text  "$COLOR_SCRIPT" "$((i+1))) $label_item"
        done

        color_text  "$COLOR_SCRIPT" "0) Exit"
        color_text  "$COLOR_SCRIPT" "=========================================="
        color_text  -n "Choice MENU: "
        read -n 1 -r choice < /dev/tty
        echo -e "\n"

        case "$choice" in
            0) 
                color_text "$YELLOW" "Завершение работы..."
                return 0 
                ;;
            [1-9])
                idx=$((choice-1))
                if (( idx >= 0 && idx < ${#MENU_ITEMS[@]} )); then
                    choice_menu_idx "$idx"
                else
                    color_text "$RED" "Пункт $choice не существует"
                    echo -e "\n"
                    sleep 1
                fi
                ;;
            *)
                color_text "$RED" "Неверный ввод. Используйте 1-9 или 0"
                sleep 1
                ;;
        esac
    done
}

upgrade_system(){
    echo -ne "${COLOR_SCRIPT}UPGRADE SYSTEM? [Y/n]: ${NC}"
    while true; do
        read -n 1 -r -s answer < /dev/tty
        case "$answer" in
            [Yy]|"") 
                color_text "$CYAN" "[+] UPDATE and UPGRADE (dist-upgrade)..."
                export DEBIAN_FRONTEND=noninteractive
                apt-get update && apt-get dist-upgrade -y
                echo "$(date +%T) DIST-UPGRADE SYSTEM == YES" > "$SESSION_DIR/apt_updated"
                if [[ -f /run/reboot-required ]]; then
                    color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                    if [[ -f /run/reboot-required.pkgs ]]; then
                        echo "[*] Packages requiring reboot:"
                        sed 's/^/    - /' /run/reboot-required.pkgs
                    fi
                fi
                break 
                ;;
            [Nn])
                color_text "$CYAN" "[-] MISSED UPGRADE."
                break 
                ;;
            *)
                ;;
        esac
    done
}

validate_ip() {
    local ip="${1:-}"
    local re='^([0-9]{1,3}\.){3}[0-9]{1,3}$'
    
    if [[ $ip =~ $re ]]; then
        IFS='.' read -r -a octets <<< "$ip"
        for octet in "${octets[@]}"; do
            if ((octet < 0 || octet > 255)); then
                return 1
            fi
        done
        return 0
    else
        return 1
    fi
}

export -f check_update
# export -f choice_menu_idx
export -f cleanup
export -f color_text
export -f input_step
export -f install_pkg
export -f setup_session
# export -f show_menu
export -f upgrade_system
export -f validate_ip