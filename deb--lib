export RED='\e[31m'
export GREEN='\e[32m'
export YELLOW='\e[33m'
export BLUE='\e[34m'
export CYAN='\e[36m'
export AQUA='\e[1;36m'
export NC='\e[0m'
color_text() {
    local color=$1
    shift
    echo -e "${color}$*${NC}"
}

install_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        color_text "$YELLOW" "[+] Install: $pkg"
        if [[ ! -f "$SESSION_DIR/apt_updated" ]]; then
            apt-get update -qq
            echo "$(date +%T) install_pkg $cmd" > "$SESSION_DIR/apt_updated"
        fi
        apt-get install -y "$pkg" || { 
            color_text "$RED" "Error: Failed to install $pkg";
            exit 1;
        }
    fi
}

setup_session() {
    local RAW_NAME="${1:-raw-session-name}"
    local SCRIPT_NAME="${0##*/}"
    
    if [[ "$SCRIPT_NAME" == "bash" || -z "$SCRIPT_NAME" ]]; then
        export SESSION_NAME=$RAW_NAME
    else
        export SESSION_NAME="${SCRIPT_NAME%.*}"
    fi
    export SESSION_DIR=$(mktemp -d -t "${SESSION_NAME}-XXXXXXXXXX")
    if [[ ! -d "$SESSION_DIR" ]]; then
        color_text "$RED" "Критическая ошибка: Не удалось создать SESSION_DIR" >&2
        return 1
    fi
}

cleanup() {
    rm -rf "$SESSION_DIR"
}

upgrade_system(){
    echo -ne "${COLOR_SCRIPT}UPGRADE SYSTEM? [Y/n]: ${NC}"
    while true; do
        read -n 1 -r -s answer < /dev/tty
        case "$answer" in
            [Yy]|"") 
                echo "[+] UPDATE and UPGRADE (dist-upgrade)..."
                export DEBIAN_FRONTEND=noninteractive
                apt-get update && apt-get dist-upgrade -y
                echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
                if [[ -f /run/reboot-required ]]; then
                    color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                    if [[ -f /run/reboot-required.pkgs ]]; then
                        echo "[*] Packages requiring reboot:"
                        sed 's/^/    - /' /run/reboot-required.pkgs
                    fi
                fi
                break 
                ;;
            [Nn])
                echo "[-] MISSED UPGRADE."
                break 
                ;;
            *)
                ;;
        esac
    done
}

show_main_menu() {
    while true; do
        # clear
        color_text "$COLOR_SCRIPT" "=========================================="
        color_text "$COLOR_SCRIPT" "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
        color_text "$COLOR_SCRIPT" "=========================================="

        for i in "${!MENU_ITEMS[@]}"; do
            raw_label_item="${MENU_ITEMS[$i]}"
            label_item="${raw_label_item%%|*}"
            label_item="${label_item#"${label_item%%[![:space:]]*}"}"
            label_item="${label_item%"${label_item##*[![:space:]]}"}"
            color_text "$COLOR_SCRIPT" "$((i+1))) $label_item"
        done

        color_text "$COLOR_SCRIPT" "0) Exit"
        color_text "$COLOR_SCRIPT" "=========================================="
        echo -ne "${COLOR_SCRIPT}Choice MENU: ${NC}"
        read -n 1 -r choice < /dev/tty
        echo -e "\n" # Перенос, чтобы логи не слиплись

        # 3. Диспетчер выбора
        case "$choice" in
            0) 
                color_text "$YELLOW" "Завершение работы..."
                exit 0 
                ;;
            [1-9])
                idx=$((choice-1))
                # Проверка: индекс должен быть в рамках массива
                if (( idx >= 0 && idx < ${#MENU_ITEMS[@]} )); then
                    handle_module "$idx"
                else
                    color_text "$RED" "Пункт $choice не существует"
                    sleep 1
                fi
                ;;
            *)
                color_text "$RED" "Неверный ввод. Используйте 1-9 или 0"
                sleep 1
                ;;
        esac
    done
}

handle_module{
    local idx=$1
    local label=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f1 | xargs)
    local filename=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f2 | xargs)
    local module_path="$SESSION_DIR/$filename"

    echo -e "\n[>>>] Модуль: $label"
    
    # 1. Скачиваем. Флаг -f (fail) не создаст файл, если на сервере 404
    if curl -sL -f "$BASE_URL/$filename" -o "$module_path"; then
        color_text "$CYAN" "[OK] Запуск модуля..."
        echo "------------------------------------------"
        
        # 2. Запуск через source, чтобы модуль видел наши функции (install_pkg и т.д.)
        # Но если хочешь полной изоляции — используй: bash "$module_path"
        if ! source "$module_path"; then
            color_text "$RED" "[!] Модуль завершился с ошибкой."
        fi
        
        echo "------------------------------------------"
        read -n1 -rs -p "Нажмите любую клавишу для возврата в меню..."
    else
        color_text "$RED" "[!] Ошибка: Файл $filename не найден на сервере $BASE_URL"
        sleep 2
    fi
}


export -f install_pkg
export -f color_text
export -f setup_session
export -f cleanup