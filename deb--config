set -euo pipefail

# --- Check user ROOT ---
die() {
    echo "[!] $1 [!]" >&2
    exit 1
}
if [[ $EUID -ne 0 ]]; then
    die "Run is not root"
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if [[ "${DEB_LIB_STATUS:-}" != "loaded" ]]; then
    if source <(curl -sL https://mls.sk87.top/deb--lib); then
        export DEB_LIB_STATUS = "loaded"
        COLOR_SCRIPT=$CYAN
        color_text "$COLOR_SCRIPT" "[✓] deb--lib LOADED"
    else
        echo "ERROR: not loaded deb--lib" >&2
        exit 1
    fi
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
source /etc/os-release
RAW_NAME="raw--deb--config"
setup_session $RAW_NAME
trap cleanup EXIT
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
color_text "$COLOR_SCRIPT" "[✓] Session context initialized: $SESSION_DIR"

# --- 2. SYSTEM UPGRADE ---
echo -n "UPGRADE SYSTEM? [Y/n]: "
while true; do
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            echo "[+] UPDATE and UPGRADE (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
            if [[ -f /run/reboot-required ]]; then
                 color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                 if [[ -f /run/reboot-required.pkgs ]]; then
                     echo "[*] Packages requiring reboot:"
                     sed 's/^/    - /' /run/reboot-required.pkgs
                 fi
            fi
            break 
            ;;
        [Nn])
            echo "[-] MISSED UPGRADE."
            break 
            ;;
        *)
            ;;
    esac
done

# --- 3. DEPENDENCIES ---
install_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "[+] Install: $pkg"
        if [ "$APT_UPDATED" = false ]; then
            apt-get update -qq
            echo "$(date +%T) install_pkg $cmd" > "$SESSION_DIR/apt_updated"
        fi
        apt-get install -y "$pkg" || { echo "Error: Failed to install $pkg"; exit 1; }
    fi
}

# Install curl
install_pkg "curl"

# --- 4. WRAPPER LOGIC ---
BASE_URL="https://mls.sk87.top"

MENU_ITEMS=(
  "Install netsoft              | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening         | deb--config-ssh"
  "Add Sudo User                | deb--config-newuser"
)

while true; do
    color_text "$COLOR_SCRIPT" "=========================================="
    color_text "$COLOR_SCRIPT" "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
    color_text "$COLOR_SCRIPT" "=========================================="
    for i in "${!MENU_ITEMS[@]}"; do
        label=$(echo "${MENU_ITEMS[$i]}" | cut -d'|' -f1 | xargs)
        color_text "$COLOR_SCRIPT" "$((i+1))) $label"
    done
    color_text "$COLOR_SCRIPT" "0) Выход"
    color_text "$COLOR_SCRIPT" "=========================================="
    color_text "$COLOR_SCRIPT" "Выберите пункт (нажмите цифру): \c"
    read -n 1 -r -s choice < /dev/tty
    color_text "$COLOR_SCRIPT" "$choice"
    [[ "$choice" == "0" ]] && exit 0

    # Проверка: является ли нажатая клавиша цифрой и попадает ли в диапазон меню
    if [[ "$choice" =~ ^[1-9]$ ]] && (( choice <= ${#MENU_ITEMS[@]} )); then
        idx=$((choice-1))
        filename=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f2 | xargs)
        
        echo -e "\n[>>>] Загрузка модуля: $filename"
        if curl -s -f "$BASE_URL/$filename" -o "$SESSION_DIR/$filename"; then
            echo "[OK] Запуск модуля..."
            echo "------------------------------------------"
            bash "$SESSION_DIR/$filename"
            echo "------------------------------------------"
        else
            echo "[!] Ошибка: Файл $filename не найден на сервере." >&2
        fi
    else
        echo -e "\n[!] Неверный выбор: '$choice'. Используйте цифры 0-${#MENU_ITEMS[@]}."
    fi
done
