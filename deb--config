set -euo pipefail
. /etc/os-release
if [[ $EUID -ne 0 ]]; then
    echo "[!] run is not root [!] Run as root: sudo bash $0" >&2
    exit 1
fi

MENU_ITEMS=(
  "Install netsoft|deb__config_netsoft|https://mls.sk87.top/deb--config-netsoft"
  "Config network|deb__config_network|https://mls.sk87.top/deb--config-network"
  "Config ssh|deb__config_ssh|https://mls.sk87.top/deb--config-ssh"
  "Add sudouser|deb__config_newuser|https://mls.sk87.top/deb--config-newuser"
  "Install and config nftables|deb__config_nftables|https://mls.sk87.top/deb--config-nftables"
)
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#

# config-NETSOFT
deb__config_netsoft(){
wget https://mls.sk87.top/deb--config-netsoft
bash deb--config-netsoft
wait 2
}

# config-NETWORK
deb__config_network(){
wget https://mls.sk87.top/deb--config-network
bash deb--config-network
wait 2
}

# config-SSH
deb__config_ssh(){
wget https://mls.sk87.top/deb--config-ssh
bash deb--config-ssh
wait 2
}

# config-NEWUSER
deb__config_newuser(){
wget https://mls.sk87.top/deb--config-newuser
bash deb--config-newuser
wait 2
}

# config-NFTABLES
deb__config_nftables(){
wget https://mls.sk87.top/deb--config-nftables
bash deb--config-nftables
wait 2
}

show_menu() {
  echo "=============================="
  echo "       Menu deb--config       "
  echo "=============================="
  local i=1 item menu_name menu_func menu_desc
  for item in "${MENU_ITEMS[@]}"; do
    IFS='|' read -r menu_name menu_func menu_desc <<< "$item"
    printf "%2d) %s\n" "$i" "$menu_name"
    [[ -n "${menu_desc:-}" ]] && printf "    - %s\n" "$menu_desc"
    i=$((i+1))
  done
  echo " 0) Выход"
  echo
}
