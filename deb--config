color_text "$CYAN" "[‚úì] Session context initialized: $SESSION_DIR"

# --- 2. SYSTEM UPGRADE ---
echo -n "UPGRADE SYSTEM? [Y/n]: "
while true; do
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            echo "[+] UPDATE and UPGRADE (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
            if [[ -f /run/reboot-required ]]; then
                 color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                 if [[ -f /run/reboot-required.pkgs ]]; then
                     echo "[*] Packages requiring reboot:"
                     sed 's/^/    - /' /run/reboot-required.pkgs
                 fi
            fi
            break 
            ;;
        [Nn])
            echo "[-] MISSED UPGRADE."
            break 
            ;;
        *)
            ;;
    esac
done

# --- 3. DEPENDENCIES ---
install_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "[+] Install: $pkg"
        if [ "$APT_UPDATED" = false ]; then
            apt-get update -qq
            echo "$(date +%T) install_pkg $cmd" > "$SESSION_DIR/apt_updated"
        fi
        apt-get install -y "$pkg" || { echo "Error: Failed to install $pkg"; exit 1; }
    fi
}

