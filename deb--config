set -euo pipefail

# --- Check user ROOT ---
die() {
    echo "[!] $1 [!]" >&2
    exit 1
}
if [[ $EUID -ne 0 ]]; then
    die "Run is not root"
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if ! command -v curl >/dev/null 2>&1; then
    apt-get update -qq && apt-get install -y curl >/dev/null
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if [[ "${DEB_LIB_STATUS:-}" != "loaded" ]]; then
    if source <(curl -sLf https://mls.sk87.top/deb--lib); then
        export DEB_LIB_STATUS="loaded"
        COLOR_SCRIPT=$AQUA
        color_text "$COLOR_SCRIPT" "[✓] deb--lib LOADED"
    else
        echo -e "ERROR: not loaded deb--lib" >&2
        exit 1
    fi
    else
    COLOR_SCRIPT=$AQUA
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
source /etc/os-release
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
RAW_NAME="raw--deb--config"
setup_session $RAW_NAME
tput smcup
clear
tput civis
trap cleanup EXIT
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
color_text  "$COLOR_SCRIPT" "[✓] Session context initialized: $SESSION_DIR"
upgrade_system

# --- 4. WRAPPER LOGIC ---
BASE_URL="https://mls.sk87.top"

MENU_ITEMS=(
  "Install netsoft              | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening         | deb--config-ssh"
  "Add Sudo User                | deb--config-newuser"
)

show_menu "MENU_ITEMS"
