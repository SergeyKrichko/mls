set -euo pipefail
. /etc/os-release
if [[ $EUID -ne 0 ]]; then
    echo "[!] run is not root [!] Run as root: sudo bash $0" >&2
    exit 1
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#

show_menu() {
    echo "1) install netsoft $HTOP_STATUS"
    echo "2) Config network $CURL_STATUS"
    echo "3) Config ssh $CURL_STATUS"
    echo "4) Add sudouser  $CURL_STATUS"
    echo "0) Exit"
}

while true; do
    show_menu
    read choice
    case $choice in
        1)
            if [ "$htop_installed" = false ]; then
                echo "Установливаем htop..."
                apt install -y htop
                htop_installed=true
            else
                echo "htop уже установлен."
            fi
            ;;
        2)
            if [ "$curl_installed" = false ]; then
                echo "Устанавливаем curl..."
                apt install -y curl
                curl_installed=true
            else
                echo "curl уже установлен."
            fi
            ;;
        0)
            echo "Exit."
            exit 0
            ;;
        *)
            echo "Неверный выбор. Попробуйте ещё раз."
            ;;
    esac
done



