#!/bin/bash
set -euo pipefail

# --- Check user ROOT ---
die() {
    echo "[!] $1 [!]" >&2
    exit 1
}

if [[ $EUID -ne 0 ]]; then
    die "Run is not root"
fi

#
. /etc/os-release
RAW_NAME="raw--deb--config"
SCRIPT_NAME="${0##*/}"
if [[ "$SCRIPT_NAME" == "bash" || -z "$SCRIPT_NAME" ]]; then
    SESSION_NAME=$RAW_NAME
else
    SESSION_NAME="${SCRIPT_NAME%.*}"
fi
export SESSION_DIR=$(mktemp -d -t "${SESSION_NAME}-XXXXXXXXXX")

#
cleanup() {
    rm -rf "$SESSION_DIR"
}
trap cleanup EXIT

#
echo "[*] Session context initialized: $SESSION_DIR"

# --- 2. SYSTEM UPGRADE ---
echo -n "UPGRADE SYSTEM? [Y/n]: "
while true; do
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            echo "[+] UPDATE and UPGRADE (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
            if [[ -f /run/reboot-required ]]; then
                 echo -e "\n\e[33m[!] WARNING: System reboot is required to apply updates!\e[0m"
                 if [[ -f /run/reboot-required.pkgs ]]; then
                     echo "[*] Packages requiring reboot:"
                     sed 's/^/    - /' /run/reboot-required.pkgs
                 fi
            fi
            break 
            ;;
        [Nn])
            echo "[-] MISSED UPGRADE."
            break 
            ;;
        *)
            ;;
    esac
done

smart_update() {
    if [[ -f "${SESSION_DIR:-}/apt_updated" ]]; then
        return 0
    fi
    apt-get update -qq && touch "$SESSION_DIR/apt_updated"
}

# --- 3. DEPENDENCIES ---
ensure_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "[+] Install: $pkg"
        if [ "$APT_UPDATED" = false ]; then
            apt-get update -qq
            date +%T > "$SESSION_DIR/apt_updated"
        fi
        apt-get install -y "$pkg" || { echo "Error: Failed to install $pkg"; exit 1; }
    fi
}

# Install curl
ensure_pkg "curl"

# --- 4. –§–Ю–†–Ь–Ш–†–Ю–Т–Р–Э–Ш–Х –Ь–Х–Э–Ѓ (WRAPPER LOGIC) ---
BASE_URL="https://mls.sk87.top"
TMP_DIR=$(mktemp -d)



MENU_ITEMS=(
  "Install netsoft              | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening         | deb--config-ssh"
  "Add Sudo User                | deb--config-newuser"
)

while true; do
    echo -e "\n=========================================="
    echo "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
    echo "=========================================="
    
    for i in "${!MENU_ITEMS[@]}"; do
        label=$(echo "${MENU_ITEMS[$i]}" | cut -d'|' -f1 | xargs)
        printf "%d) %s\n" $((i+1)) "$label"
    done
    echo "0) –Т—Л—Е–Њ–і"
    echo "=========================================="
    echo -n "–Т—Л–±–µ—А–Є—В–µ –њ—Г–љ–Ї—В (–љ–∞–ґ–Љ–Є—В–µ —Ж–Є—Д—А—Г): "

    # –І–Є—В–∞–µ–Љ –Ю–Ф–Ш–Э —Б–Є–Љ–≤–Њ–ї –±–µ–Ј –Њ–ґ–Є–і–∞–љ–Є—П Enter
    read -n 1 -r -s choice < /dev/tty
    echo "$choice" # –Т—Л–≤–Њ–і–Є–Љ –љ–∞–ґ–∞—В—Г—О —Ж–Є—Д—А—Г –і–ї—П –љ–∞–≥–ї—П–і–љ–Њ—Б—В–Є

    # 0 - –Т—Л—Е–Њ–і
    [[ "$choice" == "0" ]] && exit 0

    # –Я—А–Њ–≤–µ—А–Ї–∞: —П–≤–ї—П–µ—В—Б—П –ї–Є –љ–∞–ґ–∞—В–∞—П –Ї–ї–∞–≤–Є—И–∞ —Ж–Є—Д—А–Њ–є –Є –њ–Њ–њ–∞–і–∞–µ—В –ї–Є –≤ –і–Є–∞–њ–∞–Ј–Њ–љ –Љ–µ–љ—О
    if [[ "$choice" =~ ^[1-9]$ ]] && (( choice <= ${#MENU_ITEMS[@]} )); then
        idx=$((choice-1))
        filename=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f2 | xargs)
        
        echo -e "\n[>>>] –Ч–∞–≥—А—Г–Ј–Ї–∞ –Љ–Њ–і—Г–ї—П: $filename"
        if curl -s -f "$BASE_URL/$filename" -o "$TMP_DIR/$filename"; then
            echo "[OK] –Ч–∞–њ—Г—Б–Ї –Љ–Њ–і—Г–ї—П..."
            echo "------------------------------------------"
            bash "$TMP_DIR/$filename"
            echo "------------------------------------------"
        else
            echo "[!] –Ю—И–Є–±–Ї–∞: –§–∞–є–ї $filename –љ–µ –љ–∞–є–і–µ–љ –љ–∞ —Б–µ—А–≤–µ—А–µ." >&2
        fi
    else
        echo -e "\n[!] –Э–µ–≤–µ—А–љ—Л–є –≤—Л–±–Њ—А: '$choice'. –Ш—Б–њ–Њ–ї—М–Ј—Г–є—В–µ —Ж–Є—Д—А—Л 0-${#MENU_ITEMS[@]}."
    fi
done

