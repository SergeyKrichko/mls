#!/bin/bash
set -euo pipefail

# --- Check user ROOT ---
die() {
    echo "[!] $1 [!]" >&2
    exit 1
}

if [[ $EUID -ne 0 ]]; then
    die "Run is not root"
fi

#
. /etc/os-release
SCRIPT_NAME="${0##*/}"
SESSION_NAME="${SCRIPT_NAME%.*}"
export SESSION_DIR=$(mktemp -d -t "${SESSION_NAME}-XXXXXXXXXX")
APT_UPDATED=false
APT_UPGRADED=false

#
cleanup() {
    rm -rf "$SESSION_DIR"
}
trap cleanup EXIT

#
echo "[*] Session context initialized: $SESSION_DIR"

# --- 2. SYSTEM UPGRADE ---
echo -n "UPGRADE SYSTEM? [Y/n]: "
while true; do
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            echo "Yes"
            echo "[...] UPDATE and UPGRADE (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            APT_UPGRADED=true
            APT_UPDATED=true
            
            if [ -f /var/run/reboot-required ]; then
                echo -e "\n[!] WARNING: reboot!"
            fi
            break 
            ;;
        [Nn])
            echo "No"
            echo "[*] MISSED UPGRADE."
            break 
            ;;
        *)
            ;;
    esac
done

# --- 3. DEPENDENCIES ---
ensure_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "[...] Install: $pkg"
        # Обновляем кэш, только если не делали upgrade выше
        if [ "$APT_UPDATED" = false ]; then
            apt-get update -qq
            APT_UPDATED=true
        fi
        apt-get install -y "$pkg" || { echo "Error: Failed to install $pkg"; exit 1; }
    fi
}

# Install curl
ensure_pkg "curl"

# --- 4. ФОРМИРОВАНИЕ МЕНЮ (WRAPPER LOGIC) ---
BASE_URL="https://mls.sk87.top"
TMP_DIR=$(mktemp -d)



MENU_ITEMS=(
  "Install netsoft              | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening         | deb--config-ssh"
  "Add Sudo User                | deb--config-newuser"
)

while true; do
    echo -e "\n=========================================="
    echo "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
    echo "=========================================="
    
    for i in "${!MENU_ITEMS[@]}"; do
        label=$(echo "${MENU_ITEMS[$i]}" | cut -d'|' -f1 | xargs)
        printf "%d) %s\n" $((i+1)) "$label"
    done
    echo "0) Выход"
    echo "=========================================="
    echo -n "Выберите пункт (нажмите цифру): "

    # Читаем ОДИН символ без ожидания Enter
    read -n 1 -r -s choice < /dev/tty
    echo "$choice" # Выводим нажатую цифру для наглядности

    # 0 - Выход
    [[ "$choice" == "0" ]] && exit 0

    # Проверка: является ли нажатая клавиша цифрой и попадает ли в диапазон меню
    if [[ "$choice" =~ ^[1-9]$ ]] && (( choice <= ${#MENU_ITEMS[@]} )); then
        idx=$((choice-1))
        filename=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f2 | xargs)
        
        echo -e "\n[>>>] Загрузка модуля: $filename"
        if curl -s -f "$BASE_URL/$filename" -o "$TMP_DIR/$filename"; then
            echo "[OK] Запуск модуля..."
            echo "------------------------------------------"
            bash "$TMP_DIR/$filename"
            echo "------------------------------------------"
        else
            echo "[!] Ошибка: Файл $filename не найден на сервере." >&2
        fi
    else
        echo -e "\n[!] Неверный выбор: '$choice'. Используйте цифры 0-${#MENU_ITEMS[@]}."
    fi
done

