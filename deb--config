#!/bin/bash
set -euo pipefail

# --- Check user ROOT ---
if [[ $EUID -ne 0 ]]; then
   echo "[!] run is not root [!]" >&2
   echo " Run as root: sudo bash $0" >&2
   exit 1
fi

. /etc/os-release
    
# --- 2. ОБНОВЛЕНИЕ СИСТЕМЫ (UPGRADE) ---
echo -n "Выполнить полное обновление системы? [Y/n]: "
while true; do
    # -n 1 (один символ), -s (не выводить символ нажатия, выведем сами для контроля)
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            # Разрешаем Y, y или Enter (пустое значение) для согласия
            echo "Yes" # Выводим текст ответа для логов
            echo "[...] Обновление индексов и пакетов (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            
            if [ -f /var/run/reboot-required ]; then
                echo -e "\n[!] ВНИМАНИЕ: Требуется перезагрузка (reboot)!"
            fi
            break # Выход из цикла, идем дальше по скрипту
            ;;
        [Nn])
            echo "No"
            echo "[*] Обновление пропущено пользователем."
            break # Выход из цикла, идем дальше по скрипту
            ;;
        *)
            # Игнорируем любые другие клавиши, цикл продолжается
            ;;
    esac
done

# --- 3. ПОДГОТОВКА ИНСТРУМЕНТОВ (DEPENDENCIES) ---
APT_UPDATED=false

ensure_pkg() {
    local cmd=$1
    local pkg=${2:-$1}
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "[...] Установка необходимой утилиты: $pkg"
        # Обновляем кэш, только если не делали upgrade выше
        if [ "$APT_UPDATED" = false ] && [[ "$run_upgrade" =~ ^[Nn]$ ]]; then
            apt-get update -qq
            APT_UPDATED=true
        fi
        apt-get install -y "$pkg" || { echo "Error: Failed to install $pkg"; exit 1; }
    fi
}

# Ставим curl (база для скачивания модулей)
ensure_pkg "curl"

# --- 4. ФОРМИРОВАНИЕ МЕНЮ (WRAPPER LOGIC) ---
BASE_URL="https://mls.sk87.top"
TMP_DIR=$(mktemp -d)

cleanup() {
    rm -rf "$TMP_DIR"
    echo -e "\n[*] Temp directory deleted. Exit."
}
trap cleanup EXIT

MENU_ITEMS=(
  "Install netsoft             | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening        | deb--config-ssh"
  "Add Sudo User               | deb--config-newuser"
)

while true; do
    echo -e "\n=========================================="
    echo "  DEBIAN CONFIGURATOR ( mls.sk87.top )"
    echo "=========================================="
    
    for i in "${!MENU_ITEMS[@]}"; do
        label=$(echo "${MENU_ITEMS[$i]}" | cut -d'|' -f1 | xargs)
        printf "%d) %s\n" $((i+1)) "$label"
    done
    echo "0) Выход"
    echo "=========================================="
    echo -n "Выберите пункт (нажмите цифру): "

    # Читаем ОДИН символ без ожидания Enter
    read -n 1 -r -s choice < /dev/tty
    echo "$choice" # Выводим нажатую цифру для наглядности

    # 0 - Выход
    [[ "$choice" == "0" ]] && exit 0

    # Проверка: является ли нажатая клавиша цифрой и попадает ли в диапазон меню
    if [[ "$choice" =~ ^[1-9]$ ]] && (( choice <= ${#MENU_ITEMS[@]} )); then
        idx=$((choice-1))
        filename=$(echo "${MENU_ITEMS[$idx]}" | cut -d'|' -f2 | xargs)
        
        echo -e "\n[>>>] Загрузка модуля: $filename"
        if curl -s -f "$BASE_URL/$filename" -o "$TMP_DIR/$filename"; then
            echo "[OK] Запуск модуля..."
            echo "------------------------------------------"
            bash "$TMP_DIR/$filename"
            echo "------------------------------------------"
        else
            echo "[!] Ошибка: Файл $filename не найден на сервере." >&2
        fi
    else
        echo -e "\n[!] Неверный выбор: '$choice'. Используйте цифры 0-${#MENU_ITEMS[@]}."
    fi
done

TEXTCOLOR='\033[0;32m'
NC='\033[0m'

