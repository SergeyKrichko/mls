set -euo pipefail

# --- Check user ROOT ---
die() {
    echo "[!] $1 [!]" >&2
    exit 1
}
if [[ $EUID -ne 0 ]]; then
    die "Run is not root"
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if [[ "${DEB_LIB_STATUS:-}" != "loaded" ]]; then
    if source <(wget -qO- https://mls.sk87.top/deb--lib); then
        export DEB_LIB_STATUS="loaded"
        COLOR_SCRIPT=$AQUA
        color_text "$COLOR_SCRIPT" "[✓] deb--lib LOADED"
    else
        echo "ERROR: not loaded deb--lib" >&2
        return 1
    fi
    else
    COLOR_SCRIPT=$AQUA
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
source /etc/os-release
RAW_NAME="raw--deb--config"
setup_session $RAW_NAME
trap cleanup EXIT
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
color_text "$COLOR_SCRIPT" "[✓] Session context initialized: $SESSION_DIR"

# --- 2. SYSTEM UPGRADE ---
echo -n "UPGRADE SYSTEM? [Y/n]: "
while true; do
    read -n 1 -r -s answer < /dev/tty
    case "$answer" in
        [Yy]|"") 
            echo "[+] UPDATE and UPGRADE (dist-upgrade)..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update && apt-get dist-upgrade -y
            echo "$(date +%T) $SESSION_NAME" > "$SESSION_DIR/apt_updated"
            if [[ -f /run/reboot-required ]]; then
                 color_text "$RED" "[!!!] WARNING: System reboot is required to apply updates!"
                 if [[ -f /run/reboot-required.pkgs ]]; then
                     echo "[*] Packages requiring reboot:"
                     sed 's/^/    - /' /run/reboot-required.pkgs
                 fi
            fi
            break 
            ;;
        [Nn])
            echo "[-] MISSED UPGRADE."
            break 
            ;;
        *)
            ;;
    esac
done

# --- 4. WRAPPER LOGIC ---
BASE_URL="https://mls.sk87.top"

MENU_ITEMS=(
  "Install netsoft              | deb--config-netsoft"
  "Config network (Static/DHCP) | deb--config-network"
  "Config SSH Hardening         | deb--config-ssh"
  "Add Sudo User                | deb--config-newuser"
)

show_main_menu
