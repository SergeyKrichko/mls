#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=# 
set -euo pipefail
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if ! command -v curl >/dev/null 2>&1; then
    apt-get update -qq && apt-get install -y curl >/dev/null
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
if [[ "${DEB_LIB_STATUS:-}" != "loaded" ]]; then
    if source <(curl -sLf https://mls.sk87.top/deb--lib); then
        export DEB_LIB_STATUS="loaded"
        COLOR_SCRIPT=$GREEN
        color_text "$COLOR_SCRIPT" "[✓] deb--lib LOADED"
    else
        echo -e "ERROR: not loaded deb--lib" >&2
        exit 1
    fi
    else
    COLOR_SCRIPT=$GREEN
fi
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
source /etc/os-release
check_update
#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#
color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> START Configuration..."

CONFIG_FILE="/etc/network/interfaces"
IFACE=""
DEFAULT_IFACE=$(ip -o -4 route show to default | awk '{print $5}' | head -n1)
all_interfaces=$(ls /sys/class/net | grep -v 'lo' | tr '\n' ' ')

color_text "$COLOR_SCRIPT" ">>> Обнаружены интерфейсы: $all_interfaces"
color_text "$COLOR_SCRIPT" "Рекомендованный (GW): ${DEFAULT_IFACE:-"не найден"}"
color_text "$COLOR_SCRIPT" "--------------------------------------------------------"

color_text -n "$COLOR_SCRIPT" "Выберите интерфейс [По умолчанию: $DEFAULT_IFACE] (5 сек): "
for ((i=5; i>0; i--)); do
    echo -ne "\rВыберите интерфейс [По умолчанию: $DEFAULT_IFACE] ($i сек): "
    if read -t 1 -r -n1 user_input < /dev/tty; then
        IFACE=$user_input
        break
    fi
done

echo "" # Перенос строки после цикла

if [[ -z "$IFACE" ]]; then
    if [[ -n "$DEFAULT_IFACE" ]]; then
        color_text "$COLOR_SCRIPT" "[i] Время вышло. Автовыбор: $DEFAULT_IFACE"
        IFACE=$DEFAULT_IFACE
    else
        color_text "$RED" "[!] Тайм-аут, а дефолтный интерфейс не найден. Введите вручную."
        input_step "Interface name" "IFACE" "ANY" || exit 1
    fi
else
    if ! ls /sys/class/net | grep -qw "$IFACE"; then
        color_text "$RED" "[!] Ошибка: '$IFACE' не существует. Откат к $DEFAULT_IFACE"
        IFACE=$DEFAULT_IFACE
    fi
fi

[[ -z "$IFACE" ]] && { color_text "$RED" "Критическая ошибка: интерфейс не выбран."; exit 1; }

color_text "$GREEN" "[✓] Работаем с интерфейсом: $IFACE"




color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Interface found: $IFACE"
color_text "$COLOR_SCRIPT" "Select network setup type:"
color_text "$COLOR_SCRIPT" "d) Dynamic (DHCP)"
color_text "$COLOR_SCRIPT" "s) Static IP"
color_text -n "$COLOR_SCRIPT" "Enter d or s: "
read -rn1 MODE < /dev/tty
echo ""

cp "$CONFIG_FILE" "$CONFIG_FILE.bak"

if [[ "$MODE" == "d" ]]; then
    color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> DHCP Configuration..."
    cat > "$CONFIG_FILE" <<EOF
auto lo
iface lo inet loopback

auto $IFACE
iface $IFACE inet dhcp
EOF

elif [[ "$MODE" == "s" ]]; then
    input_step "Static IP: "  "IP_ADDR" "IP" || exit 0
    input_step "Netmask: "    "NETMASK" "IP" || exit 0
    input_step "Gateway: "    "GATEWAY" "IP" || exit 0
    input_step "DNS: "        "DNS"     "IP" || exit 0

    color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Setting up a static IP..."

    cat > "$CONFIG_FILE" <<EOF
auto lo
iface lo inet loopback

auto $IFACE
iface $IFACE inet static
    address $IP_ADDR
    netmask $NETMASK
    gateway $GATEWAY
EOF

echo "nameserver $DNS" > /etc/resolv.conf
else
    color_text "$RED" "==>>==>>==>> [CONFIG-NETWORK][!] ->->-> Interrupted. No changes made."
    return 1
fi

# 3. Применение настроек
color_text "$YELLOW" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Restarting interface $IFACE..."
systemctl enable --now systemd-networkd
networkctl reload
networkctl reconfigure "$IFACE"
color_text "$GREEN" "==>>==>>==>> [CONFIG-NETWORK][✓] ->->-> Configuration completed!"