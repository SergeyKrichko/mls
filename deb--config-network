#!/bin/bash
#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=# 
# https://mls.sk87.top/deb--config-network
# Sergey Krichko
#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=#=# 
set -euo pipefail
. /etc/os-release

# 0. Загрузка библиотеки
if [[ "${DEB_LIB_STATUS:-}" != "loaded" ]]; then
    if source <(wget -qO- https://mls.sk87.top/deb--lib); then
        export DEB_LIB_STATUS="loaded"
        COLOR_SCRIPT=$GREEN
        color_text "$COLOR_SCRIPT" "[✓] deb--lib LOADED"
    else
        echo "ERROR: not loaded deb--lib" >&2
        exit 1
    fi
else
    COLOR_SCRIPT=$GREEN
fi

# 1. [CONFIG-NETWORK] Инициализация
color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> START Configuration..."

CONFIG_FILE="/etc/network/interfaces"
# Автоопределение интерфейса (безопасный вариант)
IFACE=$(ip -o -4 route show to default | awk '{print $5}' | head -n1)

if [[ -z "${IFACE:-}" ]]; then
    color_text "$RED" "[!] Ошибка: Активный сетевой интерфейс не найден."
    exit 1
fi

color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Interface found: $IFACE"
color_text "$COLOR_SCRIPT" "Select network setup type:"
color_text "$COLOR_SCRIPT" "d) Dynamic (DHCP)"
color_text "$COLOR_SCRIPT" "s) Static IP"

# Используем нашу новую функцию с флагом -n
color_text -n "$COLOR_SCRIPT" "Enter d or s: "
read -rn1 MODE < /dev/tty
echo "" # Перенос строки после нажатия клавиши

# Создание бэкапа
cp "$CONFIG_FILE" "$CONFIG_FILE.bak"

# 2. Логика конфигурации
if [[ "$MODE" == "d" ]]; then
    color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> DHCP Configuration..."

    cat > "$CONFIG_FILE" <<EOF
auto lo
iface lo inet loopback

auto $IFACE
iface $IFACE inet dhcp
EOF

elif [[ "$MODE" == "s" ]]; then
    # ВНИМАНИЕ: В Bash 'read -p' принимает текст приглашения, а не переменную.
    # Правильный синтаксис: read -p "Prompt" VARIABLE
    
    color_text -n "$COLOR_SCRIPT" "Enter a static IP address (e.g. 192.168.1.100): "
    read -r IP_ADDR < /dev/tty
    
    color_text -n "$COLOR_SCRIPT" "Enter a subnet mask (e.g. 255.255.255.0): "
    read -r NETMASK < /dev/tty
    
    color_text -n "$COLOR_SCRIPT" "Enter a gateway (e.g. 192.168.1.1): "
    read -r GATEWAY < /dev/tty
    
    color_text -n "$COLOR_SCRIPT" "Enter a DNS server(s) (e.g. 8.8.8.8 1.1.1.1): "
    read -r DNS < /dev/tty

    # Проверка на пустые переменные (из-за set -u)
    : "${IP_ADDR:?IP адрес не может быть пустым}"
    : "${NETMASK:?Маска не может быть пустой}"
    : "${GATEWAY:?Шлюз не может быть пустым}"

    color_text "$COLOR_SCRIPT" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Setting up a static IP..."

    cat > "$CONFIG_FILE" <<EOF
auto lo
iface lo inet loopback

auto $IFACE
iface $IFACE inet static
    address $IP_ADDR
    netmask $NETMASK
    gateway $GATEWAY
    dns-nameservers $DNS
EOF

else
    color_text "$RED" "==>>==>>==>> [CONFIG-NETWORK][!] ->->-> Interrupted. No changes made."
    exit 1
fi

# 3. Применение настроек
color_text "$YELLOW" "==>>==>>==>> [CONFIG-NETWORK] ->->-> Restarting interface $IFACE..."

# В современных Debian лучше использовать ip link set или systemctl restart networking,
# но ifdown/ifup — это классика для /etc/network/interfaces
ifdown "$IFACE" --force || true 
ifup "$IFACE"

# Финал
color_text "$GREEN" "==>>==>>==>> [CONFIG-NETWORK][✓] ->->-> Configuration completed!"